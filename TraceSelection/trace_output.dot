digraph CFG {
  rankdir=TB;
  node [shape=box, fontname=Helvetica];
  B0 [label="B0: ENTRY", style="filled", fillcolor="lightyellow"];
  B1 [label="B1: result = 0\nIF[0] x >= 0", style="filled", fillcolor="lightyellow"];
  B2 [label="B2: result = x + 10", style="filled", fillcolor="lightyellow"];
  B3 [label="B3: result = -x"];
  B4 [label="B4: JOIN\nreturn result", style="filled", fillcolor="lightyellow"];
  B5 [label="B5: EXIT", style="filled", fillcolor="lightyellow"];
  B0 -> B1 [color="red", penwidth=2.0];
  B1 -> B2 [label="True | 0.90", color="red", penwidth=2.0];
  B1 -> B3 [label="False | 0.10", color="blue", style="dashed"];
  B2 -> B4 [color="red", penwidth=2.0];
  B3 -> B4 [color="blue", style="dashed"];
  B4 -> B5 [color="red", penwidth=2.0];
}
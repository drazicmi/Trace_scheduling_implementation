digraph CFG {
  rankdir=TB;
  node [shape=box, fontname=Helvetica];
  B0 [label="B0: ENTRY"];
  B1 [label="B1: cond = True\nextra = 7\nIF cond"];
  B2 [label="B2: b = 1\ne = extra * 2\nb = b + 10\nf = e + 3\nb = b * 2"];
  B3 [label="B3: c = 2\ne = extra + 1\nc = c + 5\nf = e - 1"];
  B4 [label="B4: JOIN\nd = b if cond else c\ng = e + f\nd = d + 100\nresult = d + g"];
  B5 [label="B5: EXIT"];
  B0 -> B1;
  B1 -> B2 [label="True\np=0.70"];
  B1 -> B3 [label="False\np=0.30"];
  B2 -> B4;
  B3 -> B4;
  B4 -> B5;
}
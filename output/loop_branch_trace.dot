digraph CFG {
  rankdir=TB;
  node [shape=box, fontname=Helvetica];
  B0 [label="B0: ENTRY", style=filled, fillcolor=lightyellow];
  B1 [label="B1: N = 10\ntotal = 0\neven_count = 0", style=filled, fillcolor=lightyellow];
  B2 [label="B2: FOR i in range(N)", style=filled, fillcolor=lightyellow];
  B3 [label="B3: total = total + i\nIF i % 2 == 0", style=filled, fillcolor=lightyellow];
  B4 [label="B4: result = total + even_count"];
  B5 [label="B5: even_count = even_count + 1\ntemp = i * 2", style=filled, fillcolor=lightyellow];
  B6 [label="B6: temp = i * 3"];
  B7 [label="B7: JOIN", style=filled, fillcolor=lightyellow];
  B8 [label="B8: EXIT"];
  B0 -> B1;
  B1 -> B2;
  B2 -> B3 [label="next\np=0.90"];
  B2 -> B4 [label="done\np=0.10"];
  B3 -> B5 [label="True\np=0.70"];
  B3 -> B6 [label="False\np=0.30"];
  B5 -> B7;
  B6 -> B7;
  B7 -> B2 [label="back"];
  B4 -> B8;
}
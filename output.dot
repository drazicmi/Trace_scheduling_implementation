digraph CFG {
  rankdir=TB;
  node [shape=box, fontname=Helvetica];
  B0 [label="B0: ENTRY"];
  B1 [label="B1: FOR i in range(1, 10)"];
  B2 [label="B2: a = 2\nb = 4\na += i"];
  B3 [label="B3: AFTER_FOR\nWHILE True"];
  B4 [label="B4: break"];
  B5 [label="B5: AFTER_LOOP"];
  B6 [label="B6: EXIT"];
  B0 -> B1;
  B1 -> B2 [label="next"];
  B1 -> B3 [label="done"];
  B2 -> B1 [label="back"];
  B3 -> B4 [label="True"];
  B3 -> B5 [label="False"];
  B4 -> B3 [label="back"];
  B5 -> B6;
}
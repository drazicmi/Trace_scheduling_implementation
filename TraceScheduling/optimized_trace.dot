digraph CFG {
  rankdir=TB;
  node [shape=box, fontname=Helvetica];
  B0 [label="B0: ENTRY", style="filled", fillcolor="lightyellow"];
  B1 [label="B1: base = x + 1\nIF[0] x > 2\nshared2 = base + z", style="filled", fillcolor="lightyellow"];
  B2 [label="B2: p = x + y\nq = z + w\nmixed = p + q\nlight = y + 1\ndeep = mixed * 2\nbranch_result = deep + light", style="filled", fillcolor="lightyellow"];
  B3 [label="B3: p = x - y\nq = z - w\nbranch_result = p - q"];
  B4 [label="B4: JOIN\nshared1 = branch_result + 10\nfinal = shared1 + shared2\nreturn final", style="filled", fillcolor="lightyellow"];
  B5 [label="B5: EXIT", style="filled", fillcolor="lightyellow"];
  B6 [label="B6: SPLIT_COMP: shared2 = base + z", color="purple", style="filled", fillcolor="purple"];
  B7 [label="B7: JOIN_COMP: shared2 = base + z", color="purple", style="filled", fillcolor="purple"];
  B0 -> B1 [color="red", penwidth=2.0];
  B1 -> B2 [label="True | 0.83", color="red", penwidth=2.0];
  B2 -> B4 [color="red", penwidth=2.0];
  B4 -> B5 [color="red", penwidth=2.0];
  B1 -> B6 [label="split_comp_False", color="purple", penwidth=2.0];
  B6 -> B3 [label="resume"];
  B3 -> B7 [label="join_comp_", color="purple", penwidth=2.0];
  B7 -> B4 [label="resume"];
}
digraph CFG {
  rankdir=TB;
  node [shape=box, fontname=Helvetica];
  B0 [label="B0: ENTRY", style="filled", fillcolor="lightyellow"];
  B1 [label="B1: base = x + 1\nratio = w + 1\nIF[0] x > 2\nshared2 = base + z", style="filled", fillcolor="lightyellow"];
  B2 [label="B2: p = x + y\nq = z + w\nmixed = p + q\nlight = y + 1\ndeep = mixed * 2\nshared3 = ratio + shared2\nbranch_result = deep + light", style="filled", fillcolor="lightyellow"];
  B3 [label="B3: p = x - y\nq = z - w\nbranch_result = p - q"];
  B4 [label="B4: JOIN\nshared1 = branch_result + 10\nIF[1] y > 5", style="filled", fillcolor="lightyellow"];
  B5 [label="B5: r = branch_result + shared1\ns = r + shared2\nsecond_result = s * 2", style="filled", fillcolor="lightyellow"];
  B6 [label="B6: second_result = branch_result - shared1"];
  B7 [label="B7: JOIN\nfinal = second_result + shared3\nreturn final", style="filled", fillcolor="lightyellow"];
  B8 [label="B8: EXIT", style="filled", fillcolor="lightyellow"];
  B9 [label="B9: SPLIT_COMP: shared2 = base + z", color="purple", style="filled", fillcolor="purple"];
  B10 [label="B10: SPLIT_COMP: shared3 = ratio + shared2", color="purple", style="filled", fillcolor="purple"];
  B11 [label="B11: JOIN_COMP: shared3 = ratio + shared2", color="purple", style="filled", fillcolor="purple"];
  B0 -> B1 [color="red", penwidth=2.0];
  B1 -> B2 [label="True | 0.83", color="red", penwidth=2.0];
  B2 -> B4 [color="red", penwidth=2.0];
  B4 -> B5 [label="True | 0.67", color="red", penwidth=2.0];
  B5 -> B7 [color="red", penwidth=2.0];
  B6 -> B7 [color="blue", style="dashed"];
  B7 -> B8 [color="red", penwidth=2.0];
  B1 -> B9 [label="split_comp_False", color="purple", penwidth=2.0];
  B9 -> B3 [label="resume"];
  B4 -> B10 [label="split_comp_False", color="purple", penwidth=2.0];
  B10 -> B6 [label="resume"];
  B3 -> B11 [label="join_comp_", color="purple", penwidth=2.0];
  B11 -> B4 [label="resume"];
}
digraph CFG {
  rankdir=TB;
  node [shape=box, fontname=Helvetica];
  B0 [label="B0: ENTRY"];
  B1 [label="B1: result = 0\nIF[0] x >= 0"];
  B2 [label="B2: result = x + 10"];
  B3 [label="B3: result = -x"];
  B4 [label="B4: JOIN\nreturn result"];
  B5 [label="B5: EXIT"];
  B0 -> B1;
  B1 -> B2 [label="True | 0.90"];
  B1 -> B3 [label="False | 0.10"];
  B2 -> B4;
  B3 -> B4;
  B4 -> B5;
}